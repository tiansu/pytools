{
  "$schema": "https://najie.app/schemas/sub-app-manifest.json",
  "name": "pytools",
  "displayName": "Python 工具集",
  "version": "1.0.0",
  "description": "Python 开发工具集 - 代码格式化、检查、依赖管理、虚拟环境管理",
  "required": false,
  "capabilities": [
    "python.format",
    "python.lint", 
    "python.deps",
    "python.venv",
    "python.execute"
  ],
  "cli": {
    "enabled": true,
    "bin": "./bin/pytools.js",
    "commands": {
      "format": {
        "description": "格式化 Python 代码（使用 black/autopep8）",
        "args": {
          "path": "文件或目录路径",
          "formatter": "格式化工具（black/autopep8）"
        }
      },
      "lint": {
        "description": "检查 Python 代码质量（使用 pylint/flake8）",
        "args": {
          "path": "文件或目录路径",
          "linter": "检查工具（pylint/flake8）"
        }
      },
      "deps": {
        "description": "管理 Python 项目依赖",
        "args": {
          "action": "操作（list/install/update/remove）",
          "package": "包名（可选）"
        }
      },
      "venv": {
        "description": "管理 Python 虚拟环境",
        "args": {
          "action": "操作（create/activate/delete/list）",
          "name": "环境名称"
        }
      },
      "run": {
        "description": "执行 Python 脚本",
        "args": {
          "script": "脚本路径",
          "args": "脚本参数"
        }
      }
    }
  },
  "api": {
    "enabled": false
  },
  "ui": {
    "enabled": true,
    "entry": "./ui/dist/index.html",
    "port": 5176,
    "buildCommand": "npm run build",
    "startCommand": "npm run subapp"
  },
  "dev": {
    "systemPrompt": "./dev/prompt.md",
    "docsRoot": "./doc/开发文档/",
    "contextIncludes": ["readme", "commands", "structure"],
    "memories": {
      "enabled": true,
      "storePath": "./dev/memories/",
      "autoExtract": true,
      "maxContextMemories": 20
    }
  },
  "dependencies": {
    "runtime": []
  }
}